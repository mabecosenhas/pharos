        <rebuildPropChanged>true</rebuildPropChanged>
      </toolsSet>
      <compileType>
        <cTool>
          <commandlineTool>$$PHAROS_ARM_AARCH64_CC</commandlineTool>
          <incDir>
            <pElem>${PHAROS_FILE_PATH}/Kernel/common/include</pElem>
            <pElem>${PHAROS_FILE_PATH}/Hal/Arm/architecture/v8/Archv8-A/include</pElem>
