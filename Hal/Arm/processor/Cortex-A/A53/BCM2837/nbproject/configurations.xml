            <pElem>${PHAROS_FILE_PATH}/Hal/memory/MemoryAreaSingle/include</pElem>
            <pElem>${PHAROS_FILE_PATH}/Kernel/clock/ClockPending/include</pElem>
          </incDir>
          <commandLine>-O0 -g -mcpu=cortex-a53 -ffunction-sections -fdata-sections -Wall -Wextra -Wno-unused-parameter -Wno-unused-function</commandLine>
