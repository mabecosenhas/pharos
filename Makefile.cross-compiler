###########################################################################################
# QEMU
###########################################################################################

qemu-prepare:
	wget -nc https://download.qemu.org/qemu-$(QEMU_VERSION).tar.bz2 -P ~/cross-compiler/archive
	mkdir -p ~/cross-compiler/build/b-qemu-$(QEMU_VERSION)
	tar xvfj ~/cross-compiler/archive/qemu-$(QEMU_VERSION).tar.bz2 -C ~/cross-compiler/build

build-qemu:
	cd ~/cross-compiler/build/b-qemu-$(QEMU_VERSION)/; ../qemu-$(QEMU_VERSION)/configure --prefix=$(HOME)/cross-compiler/qemu/$(QEMU_VERSION)/
	cd ~/cross-compiler/build/b-qemu-$(QEMU_VERSION)/; make all
	cd ~/cross-compiler/build/b-qemu-$(QEMU_VERSION)/; make install

qemu: qemu-prepare build-qemu


