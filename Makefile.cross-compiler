# Build Linaro Cross-Compiler (not working for M4). Only use this if you are sure
###########################################################################################


clean-crosscompiler-linaro:
	rm -rf ~/cross-compiler/arm


# builds the linaro compiler (note: not working for cortex-M4 with FPU). Only here for future purposes (maybe?)
build-crosscompiler-linaro: clean-crosscompiler-linaro
	
	$(call init_message, build-crosscompiler-arm);	\
	# Install ARM NONE EABI Cross Compiler
	mkdir -p ~/cross-compiler
	mkdir -p ~/cross-compiler/archive
	mkdir -p ~/cross-compiler/arm
	
	# get the Linaro cross-compiler aarch64 little and big endian for bare metal
	wget -nc https://releases.linaro.org/components/toolchain/binaries/latest/aarch64-elf/gcc-linaro-7.2.1-2017.11-x86_64_aarch64-elf.tar.xz -P ~/cross-compiler/archive
	wget -nc https://releases.linaro.org/components/toolchain/binaries/latest/aarch64_be-elf/gcc-linaro-7.2.1-2017.11-x86_64_aarch64_be-elf.tar.xz -P ~/cross-compiler/archive

	# get the Linaro cross-compiler arm-eabi little and big endian for bare metal
	wget -nc https://releases.linaro.org/components/toolchain/binaries/latest/arm-eabi/gcc-linaro-7.2.1-2017.11-x86_64_arm-eabi.tar.xz -P ~/cross-compiler/archive
	wget -nc https://releases.linaro.org/components/toolchain/binaries/latest/armeb-eabi/gcc-linaro-7.2.1-2017.11-x86_64_armeb-eabi.tar.xz -P ~/cross-compiler/archive

	# unpack them
	tar xf ~/cross-compiler/archive/gcc-linaro-7.2.1-2017.11-x86_64_aarch64-elf.tar.xz -C ~/cross-compiler/arm/
	tar xf ~/cross-compiler/archive/gcc-linaro-7.2.1-2017.11-x86_64_aarch64_be-elf.tar.xz -C ~/cross-compiler/arm/
	tar xf ~/cross-compiler/archive/gcc-linaro-7.2.1-2017.11-x86_64_arm-eabi.tar.xz -C ~/cross-compiler/arm/
	tar xf ~/cross-compiler/archive/gcc-linaro-7.2.1-2017.11-x86_64_armeb-eabi.tar.xz -C ~/cross-compiler/arm/

	# export the binary files
	export PATH=~/cross-compiler/arm/gcc-linaro-7.2.1-2017.11-x86_64_aarch64_be-elf/bin:${PATH}
	export PATH=~/cross-compiler/arm/gcc-linaro-7.2.1-2017.11-x86_64_aarch64-elf/bin:${PATH}
	#export PATH=~/cross-compiler/arm/gcc-linaro-7.2.1-2017.11-x86_64_arm-eabi/bin:${PATH}
	export PATH=~/cross-compiler/arm/gcc-linaro-7.2.1-2017.11-x86_64_armeb-eabi/bin:${PATH}


