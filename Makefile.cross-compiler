BINUTILS_VERSION=2.32
GCC_VERSION=8.2.0
GMP_VERSION=6.1.2
MPFR_VERSION=3.1.6
MPC_VERSION=1.0.3
GDB_VERSION=8.2.1
QEMU_VERSION=11.0.0

# paths where the GCC will be installed to
GCC_ARM_M4_PATH=$(HOME)/cross-compiler/arm/gcc-$(GCC_VERSION)/m4
GCC_ARM_V5_PATH=$(HOME)/cross-compiler/arm/gcc-$(GCC_VERSION)/v5
GCC_ARM_R5_BIG_PATH=$(HOME)/cross-compiler/arm/gcc-$(GCC_VERSION)/r5-big
GCC_ARM_AARCH64_PATH=$(HOME)/cross-compiler/arm/gcc-$(GCC_VERSION)/aarch64
GCC_RISCV64_PATH=$(HOME)/cross-compiler/riscv/gcc-$(GCC_VERSION)/riscv64

SHELL=/bin/bash

help:
	@echo "Unknown running option"
	@echo "Available options:"
	@echo "clean-crosscompiler-all: Clean entire cross-compiler directory (~/cross-compiler)"
	@echo "clean-crosscompiler-build: Clean cross-compiler build directories (~/cross-compiler/build)"
	@echo ""
	@echo "build-crosscompiler-all: Build cross-compilers for ARM targets (ARM9, Cortex-R5, Cortex-M4 and ARMv8-A) and RISC-V"
	@echo ""
	
define init_message
	echo;	\
	echo "*********************************************************";	\
	echo '$(1)';	\
	echo "*********************************************************";	\
	echo;	\
	echo
endef

########################################################################
# Vacuum Cleaner
########################################################################

clean-all: clean-crosscompiler-all

########################################################################
# Build Cross-Compiler
########################################################################

# Clean Cross Compiler
clean-crosscompiler-all:
	rm -rf ~/cross-compiler

clean-crosscompiler-build:
	rm -rf ~/cross-compiler/build


# builds all the necessary compilers (build-crosscompiler-linaro builds the compiler for ARM9, Cortex-R5 and ARMV8-A while build-gcc-arm builds the native gcc compiler for Cortex-M4)
build-crosscompiler-all: clean-crosscompiler-build prepare-all build-gcc-arm-all build-gcc-riscv-all


# Prepare the tools (download them, unpack, create symbolic links)
prepare-all:
		
	# get the tools sources
	wget -nc ftp://ftp.gnu.org/gnu/gcc/gcc-$(GCC_VERSION)/gcc-$(GCC_VERSION).tar.gz -P ~/cross-compiler/archive
	wget -nc ftp://ftp.gnu.org/gnu/binutils/binutils-$(BINUTILS_VERSION).tar.bz2 -P ~/cross-compiler/archive
	wget -nc http://ftp.gnu.org/gnu/gdb/gdb-$(GDB_VERSION).tar.gz -P ~/cross-compiler/archive

	# create temporary build folders
	mkdir -p ~/cross-compiler/build/b-binutils-v5-$(BINUTILS_VERSION)
	mkdir -p ~/cross-compiler/build/b-binutils-r5-$(BINUTILS_VERSION)
	mkdir -p ~/cross-compiler/build/b-binutils-m4-$(BINUTILS_VERSION)
	mkdir -p ~/cross-compiler/build/b-binutils-a64-$(BINUTILS_VERSION)
	mkdir -p ~/cross-compiler/build/b-binutils-riscv64-$(BINUTILS_VERSION)
	mkdir -p ~/cross-compiler/build/b-gcc-v5-$(GCC_VERSION)
	mkdir -p ~/cross-compiler/build/b-gcc-r5-$(GCC_VERSION)
	mkdir -p ~/cross-compiler/build/b-gcc-m4-$(GCC_VERSION)
	mkdir -p ~/cross-compiler/build/b-gcc-a64-$(GCC_VERSION)
	mkdir -p ~/cross-compiler/build/b-gcc-riscv64-$(GCC_VERSION)
	mkdir -p ~/cross-compiler/build/b-gdb-v5-$(GDB_VERSION)
	mkdir -p ~/cross-compiler/build/b-gdb-r5-$(GDB_VERSION)
	mkdir -p ~/cross-compiler/build/b-gdb-m4-$(GDB_VERSION)
	mkdir -p ~/cross-compiler/build/b-gdb-a64-$(GDB_VERSION)
	mkdir -p ~/cross-compiler/build/b-gdb-riscv64-$(GDB_VERSION)

	# unpack them
	tar xvfj ~/cross-compiler/archive/binutils-$(BINUTILS_VERSION).tar.bz2 -C ~/cross-compiler/build
	tar xvfz ~/cross-compiler/archive/gcc-$(GCC_VERSION).tar.gz -C ~/cross-compiler/build
	tar xvfz ~/cross-compiler/archive/gdb-$(GDB_VERSION).tar.gz -C ~/cross-compiler/build

	# download required MPC, MPFR and GMP
	cd ~/cross-compiler/build/gcc-$(GCC_VERSION) && ./contrib/download_prerequisites

# builds the cross-compiler for all targets
build-gcc-arm-all: build-aarch64 build-r5 build-v5 build-m4

build-gcc-riscv-all: build-riscv64


build-riscv64:
	# Install binutils
	cd ~/cross-compiler/build/b-binutils-riscv64-$(BINUTILS_VERSION) && rm -rf *
	cd ~/cross-compiler/build/b-binutils-riscv64-$(BINUTILS_VERSION); ../binutils-$(BINUTILS_VERSION)/configure --target=riscv64-unknown-elf --prefix=$(GCC_RISCV64_PATH)
	cd ~/cross-compiler/build/b-binutils-riscv64-$(BINUTILS_VERSION); make all
	cd ~/cross-compiler/build/b-binutils-riscv64-$(BINUTILS_VERSION); make install
	
	# Install GCC
	cd ~/cross-compiler/build/b-gcc-riscv64-$(GCC_VERSION) && rm -rf *
	export PATH=$(GCC_RISCV64_PATH)/bin:${PATH}; cd ~/cross-compiler/build/b-gcc-riscv64-$(GCC_VERSION); ../gcc-$(GCC_VERSION)/configure --target=riscv64-unknown-elf --prefix=$(GCC_RISCV64_PATH) --with-gnu-as --with-gnu-ld --disable-nls --disable-libssp --disable-gomp --disable-libstcxx-pch --enable-threads --disable-shared --disable-libmudflap --enable-languages=c --disable-zlib --enable-multilib --with-arch=rv64imafdc --with-abi=lp64d --with-cmodel=medany --with-libgcc-cmodel
	export PATH=$(GCC_RISCV64_PATH)/bin:${PATH}; cd ~/cross-compiler/build/b-gcc-riscv64-$(GCC_VERSION); make all-gcc
	export PATH=$(GCC_RISCV64_PATH)/bin:${PATH}; cd ~/cross-compiler/build/b-gcc-riscv64-$(GCC_VERSION); make install-gcc
	export PATH=$(GCC_RISCV64_PATH)/bin:${PATH}; cd ~/cross-compiler/build/b-gcc-riscv64-$(GCC_VERSION); make all-target-libgcc CFLAGS_FOR_TARGET='-mcmodel=medany'
	export PATH=$(GCC_RISCV64_PATH)/bin:${PATH}; cd ~/cross-compiler/build/b-gcc-riscv64-$(GCC_VERSION); make install-target-libgcc
	
	# Install GDB
	export PATH=$(GCC_RISCV64_PATH)/bin:${PATH}; cd ~/cross-compiler/build/b-gdb-riscv64-$(GDB_VERSION) && rm -rf *
	export PATH=$(GCC_RISCV64_PATH)/bin:${PATH}; cd ~/cross-compiler/build/b-gdb-riscv64-$(GDB_VERSION); ../gdb-$(GDB_VERSION)/configure --target=riscv64-unknown-elf --prefix=$(GCC_RISCV64_PATH) --disable-tui
	export PATH=$(GCC_RISCV64_PATH)/bin:${PATH}; cd ~/cross-compiler/build/b-gdb-riscv64-$(GDB_VERSION); make all
	export PATH=$(GCC_RISCV64_PATH)/bin:${PATH}; cd ~/cross-compiler/build/b-gdb-riscv64-$(GDB_VERSION); make install
	
	# copy the following lines to your .bashrc, .profile, .gnomerc
	export PHAROS_RISCV64_CC=${GCC_RISCV64_PATH}/bin/riscv64-unknown-elf-gcc
	export PHAROS_RISCV64_ARCHIVER=${GCC_RISCV64_PATH}/bin/riscv64-unknown-elf-ar
	export PHAROS_RISCV64_RANLIB=${GCC_RISCV64_PATH}/bin/riscv64-unknown-elf-ranlib
	export PHAROS_RISCV64_OBJDUMP=${GCC_RISCV64_PATH}/bin/riscv64-unknown-elf-objdump
	export PHAROS_RISCV64_OBJCOPY=${GCC_RISCV64_PATH}/bin/riscv64-unknown-elf-objcopy


